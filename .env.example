# ============================================================
# Variables d'environnement — Metal Pliage
# ============================================================
# Copier ce fichier en .env (sans .example) et remplir avec
# tes vraies valeurs. Le .env est ignoré par Git (voir .gitignore).
# NE JAMAIS partager ce fichier rempli (clés secrètes).
# ============================================================

# ----- Stripe (paiement) -----
# Dashboard : https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Secret de signature du webhook (sera fourni par "stripe listen")
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- Brevo (emails automatiques) -----
# Dashboard : https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...

# ----- Emails -----
# Email expéditeur affiché dans les emails envoyés aux clients
FROM_EMAIL=contact@metal-pliage.fr
FROM_NAME=Metal Pliage
# Email qui reçoit les notifications de nouvelles commandes
ADMIN_EMAIL=Metalpliage@gmail.com

# ----- Serveur -----
PORT=3000
